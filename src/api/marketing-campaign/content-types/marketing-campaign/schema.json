{
  "kind": "collectionType",
  "collectionName": "marketing_campaigns",
  "info": {
    "singularName": "marketing-campaign",
    "pluralName": "marketing-campaigns",
    "displayName": "Popup Campaigns List",
    "description": "Library of marketing popup designs"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "trigger_strategy": {
      "type": "dynamiczone",
      "components": [
        "marketing.trigger-onload",
        "marketing.trigger-scroll",
        "marketing.trigger-timer"
      ],
      "required": true,
      "min": 1,
      "max": 1
    },
    "content": {
      "type": "component",
      "component": "marketing.popup-content",
      "repeatable": false
    },
    "style": {
      "type": "component",
      "component": "marketing.popup-style",
      "repeatable": false
    },
    "frequency": {
      "type": "enumeration",
      "required": true,
      "default": "Once Per Session",
      "enum": [
        "Every Page Load",
        "Once Per Session",
        "Once Ever"
      ]
    },
    "target_pages": {
      "type": "text",
      "default": "*"
    }
  }
}
